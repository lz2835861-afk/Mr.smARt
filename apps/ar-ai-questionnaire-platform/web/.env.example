# Copy to .env.local and fill in. .env.local is gitignored.

# Supabase (client-side; safe to expose anon key)
VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""

# Invite-name allowlist (soft UI gate). Comma-separated, lowercase.
# VITE_INVITE_NAMES="meen,april,lindsay,lux,kevin"

# Name → collaboration role map for "我的待办". product | kevin | ar
# VITE_ROLE_MAP="kevin:kevin,meen:ar,april:ar,lindsay:ar,lux:ar"

# Kimi (Moonshot) API — SERVER-SIDE ONLY (no VITE_ prefix). Used by /api/ai.
KIMI_API_KEY=""
# Optional model override (default moonshot-v1-8k). e.g. kimi-k2-0905-preview
# KIMI_MODEL=""
