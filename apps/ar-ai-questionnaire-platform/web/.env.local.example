# Copy to .env.local and fill in your Supabase project values.
# Get these from https://supabase.com/dashboard → Project → Settings → API.

# Required for remote sync. Without these, the app falls back to localStorage only.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-key...

# Comma-separated list of team-member names. Each name doubles as
# the invite "code" AND the display name shown in the presence bar.
# Default: meen,april,lindsay,lux,kevin
VITE_INVITE_NAMES=meen,april,lindsay,lux,kevin

# HeroUI Pro install token (separate from above — used by `pnpm install` postinstall).
HEROUI_AUTH_TOKEN=your-heroui-pro-token
