{
  "manifest_version": 3,
  "name": "AR 问卷 · Provenance 溯源",
  "description": "在 docs.qq.com 上为问卷答案直接展示该问题的证据：来源 / 原文引用 / 推理 / 最终决策。",
  "version": "0.1.0",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "切换 Provenance 溯源面板",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://docs.qq.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "https://ai.ar-tencent.cloud/*",
    "http://localhost:5173/*"
  ],
  "permissions": ["storage"]
}
